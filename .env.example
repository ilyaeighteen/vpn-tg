TELEGRAM_BOT_TOKEN=123456:telegram-token

# Telegram user IDs that will always be admins on startup, comma-separated.
INITIAL_ADMIN_IDS=123456789,987654321

# Local JSON file with admins added from the bot UI.
ADMINS_FILE=admins.json

# Local JSON file with users who already interacted with the bot.
USERS_FILE=users.json

# 3x-ui panel settings.
XUI_BASE_URL=https://panel.example.com
XUI_API_TOKEN=your-3x-ui-api-token
XUI_INBOUND_ID=1

# Default client values for 3x-ui. Leave empty where not needed by your inbound.
XUI_CLIENT_FLOW=
XUI_CLIENT_LIMIT_IP=0
XUI_CLIENT_TOTAL_GB=0
XUI_CLIENT_EXPIRE_DAYS=0
XUI_CLIENT_ENABLE=true
XUI_HTTP_TIMEOUT=15s
